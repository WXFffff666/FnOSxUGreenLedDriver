#!/bin/bash
# LED Controller — Environment setup

BUNDLED_CLI="${TRIM_APPDEST}/server/ugreen_leds_cli"
SYSTEM_CLI="/usr/local/bin/ugreen_leds_cli"

echo "=== FnUGreenLed Install Init ==="

# --- 1. Load i2c-dev kernel module ---
echo "[1/4] Loading i2c-dev kernel module..."
if lsmod | grep -q i2c_dev; then
    echo "  i2c-dev already loaded"
elif modprobe i2c-dev 2>/dev/null; then
    echo "  i2c-dev loaded"
else
    echo "  WARNING: failed to load i2c-dev. Run: sudo modprobe i2c-dev"
fi

# --- 2. Add app user to i2c group (group-based access, no root needed) ---
echo "[2/4] Configuring I2C group access..."
APP_USER="${TRIM_USERNAME:-ledcontroller}"
if getent group i2c > /dev/null 2>&1; then
    if id -nG "$APP_USER" 2>/dev/null | grep -qw i2c; then
        echo "  $APP_USER already in i2c group"
    else
        usermod -a -G i2c "$APP_USER" 2>/dev/null && \
            echo "  Added $APP_USER to i2c group" || \
            echo "  WARNING: could not add $APP_USER to i2c group"
    fi
else
    echo "  No i2c group found on this system"
fi

# --- 3. Make binary setuid root as fallback ---
echo "[3/4] Configuring CLI binary..."
for CLI in "$BUNDLED_CLI" "$SYSTEM_CLI"; do
    if [ -f "$CLI" ]; then
        chown root:root "$CLI" 2>/dev/null
        chmod u+s "$CLI" 2>/dev/null
        echo "  Setuid configured: $CLI"
    fi
done

# --- 4. Verify I2C devices ---
echo "[4/4] Checking I2C devices..."
if ls /dev/i2c-* 2>/dev/null; then
    echo "  I2C devices found"
else
    echo "  WARNING: No /dev/i2c-* devices found."
    echo "  LED control requires I2C hardware support (UGREEN DXP4800 series)."
fi

echo "=== Install Init Complete ==="
exit 0
